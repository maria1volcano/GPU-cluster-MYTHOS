# Copy to `.env` (and `export $(cat .env | xargs)` or use `python-dotenv`)
# before running the agent/demo. NEVER commit a real key — `.env` is
# git-ignored on purpose.

CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/
CRUSOE_API_KEY=
CRUSOE_MODEL=nvidia/NVIDIA-Nemotron-3-Ultra-550B
CRUSOE_TIMEOUT_SECONDS=5

# Optional overrides — see sentinel/config.py for the full list & defaults.
# SENTINEL_RACK_SIZE=32
# SENTINEL_SPEEDUP=240
# SENTINEL_RNG_SEED=42
