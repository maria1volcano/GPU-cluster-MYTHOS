FROM node:20-bookworm-slim AS build

WORKDIR /app/frontend

# Build-time env (Vite bakes these into the client bundle)
ARG VITE_USE_MOCKS=false
ARG VITE_API_BASE_URL=
ARG VITE_BACKGROUND_IMAGE=/backgrounds/cluster-bg.jpg

ENV VITE_USE_MOCKS=$VITE_USE_MOCKS \
    VITE_API_BASE_URL=$VITE_API_BASE_URL \
    VITE_BACKGROUND_IMAGE=$VITE_BACKGROUND_IMAGE \
    NODE_ENV=production

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ ./

RUN npm run build

FROM node:20-bookworm-slim AS run

WORKDIR /app/frontend

ENV NODE_ENV=production

COPY --from=build /app/frontend/package.json /app/frontend/package-lock.json ./
COPY --from=build /app/frontend/node_modules ./node_modules
COPY --from=build /app/frontend/.output ./.output

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=5 \
    CMD node -e "fetch('http://127.0.0.1:3000').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["npx", "vite", "preview", "--host", "0.0.0.0", "--port", "3000"]
