# Copy to `.env` in the repo root before `docker compose up`.
# NEVER commit real keys.

# Optional — voice alerts (app works without these)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=LFZvm12tW_z0xfGo
GRADIUM_TTS_SPEED=1.8

# Optional — LLM agent (falls back to template recommendations)
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/
CRUSOE_API_KEY=
CRUSOE_MODEL=nvidia/NVIDIA-Nemotron-3-Ultra-550B
CRUSOE_TIMEOUT_SECONDS=5

# Optional server toggles
SENTINEL_TTS_ENABLED=true
SENTINEL_TTS_OPERATOR_ACTIONS=true
